/*
Genome build: Human, gencode Hg38 v42 primary assembly
*/
params{
    //fasta & co
    fai = "/path/to/genome.fa.fai"
    rRNA_fa = "/path/to/rRNA.fa"
    // annotation
    gff3 = "/path/to/genome.annotation.gff3"
    // index
    STAR_index = "/path/to/STAR_index"
    
    bbduk {
        ref = rRNA_fa
    }
    STAR {
        genomeDir = STAR_index
    }
    shoji {
        gff3 = gff3
        annotation_params = "--gene_id gene_id --gene_name gene_name --gene_type gene_type -x tRNA"
    }
    tracks{
        genome = fai
    }
}