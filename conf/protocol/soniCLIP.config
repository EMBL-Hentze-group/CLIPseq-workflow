params {
    // protocol specific parameters 
    // eCLIP specific values
    dedup = false
    two_step_trim = false
    twopass_mapping = true // two pass mapping alignment (STAR)
    // @TODO: cutadapt parameters for soniCLIP
    // cutadapt {
    //     trim = " --match-read-wildcards --times 1 -e 0.1 -O 1 --quality-cutoff 6 -m 18 -a NNNNNAGATCGGAAGAGCACACGTCTGAACTCCAGTCAC  -g CTTCCGATCTACAAGTT  -g CTTCCGATCTTGGTCCT  -A AACTTGTAGATCGGA  -A AGGACCAAGATCGGA  -A ACTTGTAGATCGGAA  -A GGACCAAGATCGGAA  -A CTTGTAGATCGGAAG  -A GACCAAGATCGGAAG  -A TTGTAGATCGGAAGA  -A ACCAAGATCGGAAGA  -A TGTAGATCGGAAGAG  -A CCAAGATCGGAAGAG  -A GTAGATCGGAAGAGC  -A CAAGATCGGAAGAGC  -A TAGATCGGAAGAGCG  -A AAGATCGGAAGAGCG  -A AGATCGGAAGAGCGT  -A GATCGGAAGAGCGTC  -A ATCGGAAGAGCGTCG  -A TCGGAAGAGCGTCGT  -A CGGAAGAGCGTCGTG  -A GGAAGAGCGTCGTGT"
    //     trim2 = "--match-read-wildcards  --times 1  -e 0.1  -O 5  --quality-cutoff 6  -m 18  -A AACTTGTAGATCGGA  -A AGGACCAAGATCGGA  -A ACTTGTAGATCGGAA  -A GGACCAAGATCGGAA  -A CTTGTAGATCGGAAG  -A GACCAAGATCGGAAG  -A TTGTAGATCGGAAGA  -A ACCAAGATCGGAAGA  -A TGTAGATCGGAAGAG  -A CCAAGATCGGAAGAG  -A GTAGATCGGAAGAGC  -A CAAGATCGGAAGAGC  -A TAGATCGGAAGAGCG  -A AAGATCGGAAGAGCG  -A AGATCGGAAGAGCGT  -A GATCGGAAGAGCGTC  -A ATCGGAAGAGCGTCG  -A TCGGAAGAGCGTCGT  -A CGGAAGAGCGTCGTG  -A GGAAGAGCGTCGTGT"
    // }
    fastp {
        trim = "-a AAAAAAAAAA --trim_poly_g --trim_poly_x --trim_front1 3 -q 6 -l 15 --low_complexity_filter --overrepresentation_analysis"
    }
    STAR {
        align_params = " --readFilesCommand zcat --outFilterMultimapScoreRange 1 --outFilterType BySJout --genomeLoad NoSharedMemory --outSAMattributes All --outFilterMultimapNmax 10 --outStd BAM_Unsorted --outSAMtype BAM Unsorted --chimSegmentMin 15 --chimMultimapNmax 20 --outSAMunmapped Within"
    }
    shoji {
        mate = 1
        site = "m"
        offset = 0
        baseName = "soniCLIP_SLBP_RBFOX2"
    }
}
