params {
    // protocol specific parameters
    demultiplex = false // for iCLIP
    // eCLIP specific values
    dedup = false
    two_step_trim = false
    twopass_mapping = true // two pass mapping alignment (STAR)
    // @TODO: cutadapt parameters for soniCLIP
    fastp {
        trim = "-a AAAAAAAAAA --trim_poly_g --trim_poly_x --trim_front1 3 -q 6 -l 15 --low_complexity_filter --overrepresentation_analysis"
        adapters = "${projectDir}/data/adapters/generic_adapters.fa"
    }
    STAR {
        align_params = " --readFilesCommand zcat --outFilterMultimapScoreRange 1 --outFilterType BySJout --genomeLoad NoSharedMemory --outSAMattributes All --outFilterMultimapNmax 10 --outStd BAM_Unsorted --outSAMtype BAM Unsorted --chimSegmentMin 15 --chimMultimapNmax 20 --outSAMunmapped Within"
    }
    shoji {
        mate = 1
        site = "m"
        offset = 0
        baseName = "soniCLIP"
    }
}
