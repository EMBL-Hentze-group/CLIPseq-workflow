params {
    // protocol specific parameters
    demultiplex = true // only for iCLIP
    bc_pattern = "NNNNXXXXXXXXNN"
    // iCLIP specific values
    dedup = true
    is_paired = false // for sake of simplicity, hard code this for now
    two_step_trim = false
    twopass_mapping = true // two pass mapping alignment (STAR)
    min_read_length = 15
    
    // @TODO: adapter parameters for iCLIP
    cutadapt{
        trim = "-a AGATCGGAAGAG -a AGATCGGAAGAG -a AGATCGGAAGAGCGGTTCAG -a AGATCGGAAGAGCACACGTC -a AGATCGGAAGAGCACACGTCTGAACTCCAGTCA -a TCGGAAGAGCGGTTCAGCAGGAATGCCGAGACCGATCT -a GAAGAGCGGTTCAGCAGGAATGCCGAGACCGATC -a GGGGGGGGGGGG -a AAAAAAAAAAAA -e 0.1 --quality-cutoff 6 -m 15 --match-read-wildcards --poly-a"
    }
    fastp {
        trim = "-a AGATCGGAAGAG --trim_poly_g --trim_poly_x -q 10 -l 15 --low_complexity_filter --overrepresentation_analysis"
        adapters = "${projectDir}/data/adapters/iCLIP.fa"
    }
    STAR{
        align_params = "--alignEndsType Extend5pOfRead1 --readFilesCommand zcat --outFilterMultimapScoreRange 1 --outFilterType BySJout --genomeLoad NoSharedMemory --outSAMattributes All --outFilterMultimapNmax 10 --outStd BAM_Unsorted --outSAMtype BAM Unsorted --chimSegmentMin 15 --chimMultimapNmax 20 --outSAMunmapped Within"
    }
    shoji{
        mate = 1
        site = "s"
        offset = -1
        baseName = "iCLIP"
    }
}

