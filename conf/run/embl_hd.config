/*
This is a modified version of the official EMBL Heidelberg config profile
*/

params {
    config_profile_contact     = "datascience-consulting@embl.org "
    config_profile_description = "The EMBL Heidelberg HPC cluster profile"
    config_profile_name        = 'EMBL_HD'
    config_profile_url         = 'https://git.embl.org/data-science/sci-workflows/nextflow-config'
}

executor {
    name = "slurm"
    queueSize = 200
    submitRateLimit = "10/1sec"
    pollInterval = '30sec'
    exitReadTimeout = "5 min"
    retry{
        // reason = "*"
        /*
        !!!! WARNING !!!!
        Dangiling '*' causes worklow to crash with cryptic error messages from version >=25.10.0
        The line above commented out until a fix is found
        */
        maxAttempt = 3
    }
}

conda {
    channels = ['http://hof.cluster.embl.de/conda-forge', 'http://hof.cluster.embl.de/bioconda']
}

docker {
    enabled = false
}

apptainer {
    enabled = true
    autoMounts = true
    pullTimeout = "3 hours"                // the default is 20 minutes and fails with large images
    envWhitelist = 'CUDA_VISIBLE_DEVICES'  // allow the bounding of GPU visible device variable into the containers
    // libraryDir = '/cvmfs/singularity.galaxyproject.org/all/'

}

singularity {
    autoMounts = true
    pullTimeout = "3 hours"
    envWhitelist = 'CUDA_VISIBLE_DEVICES'
}

process {
    def scratch_dir = System.getenv("SCRATCHDIR")
    afterScript = 'sleep 1'
    maxRetries = 4
    cache = 'lenient'
    
    /*
    queue
    !!!! WARNING !!!!
    This queue definition assumes that every process has a defined time, memory and cpus directive.
    If not, the running jobs on slurm will fail, with the error: 
        ERROR ~ Error executing process > 'processName'

        Caused by:
        Cannot invoke method div() on null object
    which is a pain in the back to debug.
    the default resources defined below should solve this
    */
    queue = { (task.time <= 14.d && task.memory < 256.GB && (task.memory.div(task.cpus)) <= 10.GB) ? "htc-el8" : "bigmem" }
    
    withLabel:gpu {
        queue = 'gpu-el8'
        containerOptions = '--nv' //enable Nvidia support
    }

    withLabel:bigmem {
        queue = 'bigmem'
    }

    withLabel:low_qos {
        clusterOptions = '--qos=low'
    }
}