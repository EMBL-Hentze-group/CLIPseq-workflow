/*
This is a modified version of the official EMBL Heidelberg config profile
*/

params {
    config_profile_contact     = "datascience-consulting@embl.org "
    config_profile_description = "The EMBL Heidelberg HPC cluster profile"
    config_profile_name        = 'EMBL_HD'
    config_profile_url         = 'https://git.embl.de/data-sciences/sci-workflows/nextflow-config'
}

executor {
    name = "slurm"
    queueSize = 200
    submitRateLimit = "10/1sec"
    pollInterval = '30sec'
    exitReadTimeout = "5 min"
    retry{
        reason = "*"
        maxAttempt = 3
    }
}

apptainer {
    enabled = true
}

process {
    def scratch_dir = System.getenv("SCRATCHDIR")
    afterScript = 'sleep 1'
    maxRetries = 4
    cache = 'lenient'
    
    /*
    queue
    !!!! WARNING !!!!
    This queue definition assumes that every process has a defined time, memory and cpus directive.
    If not, the running jobs on slurm will fail, with the error: 
        ERROR ~ Error executing process > 'processName'

        Caused by:
        Cannot invoke method div() on null object
    which is a pain in the back to debug.
    the default resources defined below should solve this
    */
    queue = { (task.time <= 14.d && task.memory < 256.GB && (task.memory.div(task.cpus)) <= 10.GB) ? "htc-el8" : "bigmem" }
    
    // resource for basic tasks
    cpus = 1
    memory = 2.GB
    time = 1.h
   
    // limits for all tasks
    resourceLimits = [ cpus: 36, memory: 280.GB, time: 120.h]
    
    // limits for tasks with specific labels
    withLabel:process_single {
        cpus   = {1}
        memory = { 15.GB * task.attempt }
        time   = { 6.h  * task.attempt }
    }

    withLabel:process_low {
        cpus   = { 5 * task.attempt }
        memory = { 8.GB * task.attempt }
        time   = { 6.h  * task.attempt }
    }

    withLabel:process_medium {
        cpus   = { 8  * task.attempt }
        memory = { 20.GB * task.attempt }
        time   = { 10.h * task.attempt }
    }

    withLabel:process_high {
        cpus   = { 12 * task.attempt }
        memory = { 50.GB * task.attempt }
        time   = { 14.h * task.attempt }
    }

    withLabel:process_highmem {
        cpus   = { 12 * task.attempt }
        memory = { 250.GB * task.attempt }
        time   = { 14.h * task.attempt }
    }

    withLabel:gpu {
        queue = 'gpu-el8'
        containerOptions = '--nv' //enable Nvidia support
    }

    withLabel:bigmem {
        queue = 'bigmem'
    }

    withLabel:low_qos {
        clusterOptions = '--qos=low'
    }
}