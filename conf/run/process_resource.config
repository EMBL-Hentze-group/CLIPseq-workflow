/*
Shared process label resource presets.
Include this file from run profiles that want standard label-based resources.
*/

process {
     // resource for basic tasks
    cpus = 1
    memory = 2.GB
    time = 1.h
    // limits for all tasks
    resourceLimits = [ cpus: 36, memory: 280.GB, time: 120.h]
    
    withLabel:process_single {
        cpus   = { 1 }
        memory = { 15.GB * task.attempt }
        time   = { 6.h * task.attempt }
    }

    withLabel:process_low {
        cpus   = { 5 * task.attempt }
        memory = { 8.GB * task.attempt }
        time   = { 6.h * task.attempt }
    }

    withLabel:process_medium {
        cpus   = { 8 * task.attempt }
        memory = { 20.GB * task.attempt }
        time   = { 10.h * task.attempt }
    }

    withLabel:process_high {
        cpus   = { 12 * task.attempt }
        memory = { 50.GB * task.attempt }
        time   = { 14.h * task.attempt }
    }

    withLabel:process_highmem {
        cpus   = { 12 * task.attempt }
        memory = { 250.GB * task.attempt }
        time   = { 14.h * task.attempt }
    }
}
