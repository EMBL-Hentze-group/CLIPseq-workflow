params{
    kraken2{
        db = "/g/hentze/sequencing/Kraken2/core_nt"
        nodes = "/g/hentze/sequencing/Kraken2/core_nt/nodes.dmp"
        names = "/g/hentze/sequencing/Kraken2/core_nt/names.dmp"
        /*
        nodes and names files: see https://ftp.ncbi.nlm.nih.gov/pub/taxonomy/taxdump_readme.txt
        */
        kraken2_params = "--use-names --confidence 0.5"
        mpa_params = "--display-header --percentages --keep-spaces"

    }
    /*
    This extra params{} block is needed to avoid nextflow error when including this config file.
    */
}
