// default output directories
params{
    out{
        QC{
            main = "QC"
            raw = "${main}/raw"
            trim = "${main}/trimm"
            rRNA = "${main}/rRNA_trim"
            kraken2 = "${main}/Kraken2"
        }
        Sourmash{
            main = "Sourmash"
            raw = "${main}/raw"
            trim = "${main}/trim"
            rRNA = "${main}/rRNA_trim"
            align = "${main}/Genome_align"
            kraken2 = "${main}/Kraken2"
        }
        Fastq{
            main = "Fastq"
            trim = "${main}/trim"
            rRNA = "${main}/rRNA_trim"
            mapped = "${main}/Genome_align/mapped"
            unmapped = "${main}/Genome_align/unmapped"
            multimapped = "${main}/Genome_align/multimapped"
        }
        Align{
            main = "Genome_align"
        }
        Shoji{
            main = "Shoji"
            annotation = "${main}/annotation"
            sites = "${main}/sites"
            counts = "${main}/counts"
            tracks = "${main}/tracks"
            matrices = "${main}/matrix"
        }
        Kraken2{
            main = "Kraken2/contamination_check"
        }
    }
}