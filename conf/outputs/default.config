// default output directories
params{
    out{
        QC{
            main = "QC"
            raw = "${params.out.QC.main}/raw"
            trim = "${params.out.QC.main}/trimm"
            rRNA = "${params.out.QC.main}/rRNA_trim"
            kraken2 = "${params.out.QC.main}/Kraken2"
        }
        Sourmash{
            main = "Sourmash"
            raw = "${params.out.Sourmash.main}/raw"
            trim = "${params.out.Sourmash.main}/trim"
            rRNA = "${params.out.Sourmash.main}/rRNA_trim"
            align = "${params.out.Sourmash.main}/Genome_align"
            kraken2 = "${params.out.Sourmash.main}/Kraken2"
        }
        Fastq{
            main = "Fastq"
            trim = "${params.out.Fastq.main}/trim"
            rRNA = "${params.out.Fastq.main}/rRNA_trim"
            mapped = "${params.out.Fastq.main}/Genome_align/mapped"
            unmapped = "${params.out.Fastq.main}/Genome_align/unmapped"
            multimapped = "${params.out.Fastq.main}/Genome_align/multimapped"
        }
        Align{
            main = "Genome_align"
        }
        Shoji{
            main = "Shoji"
            annotation = "${params.out.Shoji.main}/annotation"
            sites = "${params.out.Shoji.main}/sites"
            counts = "${params.out.Shoji.main}/counts"
            tracks = "${params.out.Shoji.main}/tracks"
            matrices = "${params.out.Shoji.main}/matrix"
        }
        Kraken2{
            main = "Kraken2/contamination_check"
        }
    }
}