// default output directories
params{
    out{
        QC{
            raw = "QC/raw"
            trim = "QC/trimm"
            rRNA = "QC/rRNA_trim"
            kraken2 = "QC/Kraken2"
        }
        Sourmash{
            raw = "Sourmash/raw"
            trim = "Sourmash/trim"
            rRNA = "Sourmash/rRNA_trim"
            align = "Sourmash/Genome_align"
            kraken2 = "Sourmash/Kraken2"
        }
        Fastq{
            trim = "Fastq/trim"
            rRNA = "Fastq/rRNA_trim"
            mapped = "Fastq/Genome_align/mapped"
            unmapped = "Fastq/Genome_align/unmapped"
            multimapped = "Fastq/Genome_align/multimapped"
        }
        Align{
            genome = "Genome_align"
        }
        Shoji{
            annotation = "Shoji/annotation"
            sites = "Shoji/sites"
            counts = "Shoji/counts"
            tracks = "Shoji/tracks"
            matrices = "Shoji/matrix"
        }
        Kraken2{
            check = "Kraken2/contamination_check"
        }
    }
}