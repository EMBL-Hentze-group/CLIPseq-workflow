singularity {
    enabled = true
}

/*
tool configs
*/
includeConfig './conf/tools/bbduk.config' //bbduk
includeConfig './conf/tools/cutadapt.config' // cutadapt
includeConfig './conf/tools/fastp.config' // fastp
includeConfig './conf/tools/kraken2.config' // kraken2
includeConfig './conf/tools/shoji.config' // shoji
includeConfig './conf/tools/sourmash.config' // sourmash
includeConfig './conf/tools/STAR.config' // STAR
includeConfig './conf/tools/tracks.config' // tracks
includeConfig './conf/tools/umi_tools.config' // umi_tools
/* 
container configs
*/
includeConfig './conf/containers/singularity.config' // singularity
/*
output configs
*/
includeConfig './conf/outputs/default.config' // output structure
/*
profiles should include protocol and genome specific configs
MUST BE loaded after tool configs so that protocol/genome specific params can override tool params
*/
profiles {
    slurm {
        includeConfig './conf/run/embl_hd.config'
    }
    // protocol
    eCLIP {
        includeConfig './conf/protocol/eCLIP.config'
    }
    soniCLIP {
        includeConfig './conf/protocol/soniCLIP.config'
    }
    // genome
    hsa {
        includeConfig './conf/genome/hsa.config'
    }
}

outputDir = '/path/to/output/dir'  // default output dir, can be overridden by params.outdir

params {
    input = "/path/to/sample_sheet.csv"
}
