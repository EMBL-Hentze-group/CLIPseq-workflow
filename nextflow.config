singularity {
    enabled = true
}

profiles {
    slurm {
        includeConfig './conf/run/embl_hd.config'
    }
    eCLIP {
        includeConfig './conf/protocol/eCLIP.config'
    }
}

outputDir = '/g/hentze/users/Sudeep/Projects/Nextflow/ENCODE/mydir'
// cleanup = true

params {
    // protocol specific parameters, default values
    dedup = false // UMI deduplication
    two_step_trim = false // two step trimming specific for eCLIP
    twopass_mapping = true // two pass mapping alignment (STAR)
    
    mode = "copy"
    input = "./data/sample_sheet.csv"
    
    cutadapt {
        trim1 = " --match-read-wildcards --times 1 -e 0.1 -O 1 --quality-cutoff 6 -m 18 -a NNNNNAGATCGGAAGAGCACACGTCTGAACTCCAGTCAC  -g CTTCCGATCTACAAGTT  -g CTTCCGATCTTGGTCCT  -A AACTTGTAGATCGGA  -A AGGACCAAGATCGGA  -A ACTTGTAGATCGGAA  -A GGACCAAGATCGGAA  -A CTTGTAGATCGGAAG  -A GACCAAGATCGGAAG  -A TTGTAGATCGGAAGA  -A ACCAAGATCGGAAGA  -A TGTAGATCGGAAGAG  -A CCAAGATCGGAAGAG  -A GTAGATCGGAAGAGC  -A CAAGATCGGAAGAGC  -A TAGATCGGAAGAGCG  -A AAGATCGGAAGAGCG  -A AGATCGGAAGAGCGT  -A GATCGGAAGAGCGTC  -A ATCGGAAGAGCGTCG  -A TCGGAAGAGCGTCGT  -A CGGAAGAGCGTCGTG  -A GGAAGAGCGTCGTGT"
        trim2 = "--match-read-wildcards  --times 1  -e 0.1  -O 5  --quality-cutoff 6  -m 18  -A AACTTGTAGATCGGA  -A AGGACCAAGATCGGA  -A ACTTGTAGATCGGAA  -A GGACCAAGATCGGAA  -A CTTGTAGATCGGAAG  -A GACCAAGATCGGAAG  -A TTGTAGATCGGAAGA  -A ACCAAGATCGGAAGA  -A TGTAGATCGGAAGAG  -A CCAAGATCGGAAGAG  -A GTAGATCGGAAGAGC  -A CAAGATCGGAAGAGC  -A TAGATCGGAAGAGCG  -A AAGATCGGAAGAGCG  -A AGATCGGAAGAGCGT  -A GATCGGAAGAGCGTC  -A ATCGGAAGAGCGTCG  -A TCGGAAGAGCGTCGT  -A CGGAAGAGCGTCGTG  -A GGAAGAGCGTCGTGT"
    }
    fastp {
        trim1 = "--disable_trim_poly_g -q 6 -l 18 -a NNNNNAGATCGGAAGAGCACACGTCTGAACTCCAGTCAC   -a CTTCCGATCTACAAGTT   -a CTTCCGATCTTGGTCCT   --adapter_sequence_r2 AACTTGTAGATCGGA   --adapter_sequence_r2 AGGACCAAGATCGGA   --adapter_sequence_r2 ACTTGTAGATCGGAA   --adapter_sequence_r2 GGACCAAGATCGGAA   --adapter_sequence_r2 CTTGTAGATCGGAAG   --adapter_sequence_r2 GACCAAGATCGGAAG   --adapter_sequence_r2 TTGTAGATCGGAAGA   --adapter_sequence_r2 ACCAAGATCGGAAGA   --adapter_sequence_r2 TGTAGATCGGAAGAG   --adapter_sequence_r2 CCAAGATCGGAAGAG   --adapter_sequence_r2 GTAGATCGGAAGAGC   --adapter_sequence_r2 CAAGATCGGAAGAGC   --adapter_sequence_r2 TAGATCGGAAGAGCG   --adapter_sequence_r2 AAGATCGGAAGAGCG   --adapter_sequence_r2 AGATCGGAAGAGCGT   --adapter_sequence_r2 GATCGGAAGAGCGTC   --adapter_sequence_r2 ATCGGAAGAGCGTCG   --adapter_sequence_r2 TCGGAAGAGCGTCGT   --adapter_sequence_r2 CGGAAGAGCGTCGTG   --adapter_sequence_r2 GGAAGAGCGTCGTGT"
        trim2 = "--disable_trim_poly_g -q 6 -l 18 --adapter_sequence_r2 AACTTGTAGATCGGA  --adapter_sequence_r2 AGGACCAAGATCGGA  --adapter_sequence_r2 ACTTGTAGATCGGAA  --adapter_sequence_r2 GGACCAAGATCGGAA  --adapter_sequence_r2 CTTGTAGATCGGAAG  --adapter_sequence_r2 GACCAAGATCGGAAG  --adapter_sequence_r2 TTGTAGATCGGAAGA  --adapter_sequence_r2 ACCAAGATCGGAAGA  --adapter_sequence_r2 TGTAGATCGGAAGAG  --adapter_sequence_r2 CCAAGATCGGAAGAG  --adapter_sequence_r2 GTAGATCGGAAGAGC  --adapter_sequence_r2 CAAGATCGGAAGAGC  --adapter_sequence_r2 TAGATCGGAAGAGCG  --adapter_sequence_r2 AAGATCGGAAGAGCG  --adapter_sequence_r2 AGATCGGAAGAGCGT  --adapter_sequence_r2 GATCGGAAGAGCGTC  --adapter_sequence_r2 ATCGGAAGAGCGTCG  --adapter_sequence_r2 TCGGAAGAGCGTCGT  --adapter_sequence_r2 CGGAAGAGCGTCGTG  --adapter_sequence_r2 GGAAGAGCGTCGTGT"
    }
    sourmash {
        sketch = "k=11,k=15,k=17,k=21,k=25,k=31,scaled=100"
        abund = true
        comparison_K = 17
    }
    bbduk {
        ref = "/g/hentze/sequencing/rRNA/human/rRNA_version2.fa"
        params = " "
    }
    STAR {
        genomeDir = "/g/hentze/sequencing/gencode/V42/Index/STAR_primary_GTF"
        align_params = " --readFilesCommand zcat --outFilterMultimapScoreRange 1 --outFilterType BySJout --genomeLoad NoSharedMemory --outSAMattributes All --outFilterMultimapNmax 10 --outStd BAM_Unsorted --outSAMtype BAM Unsorted --chimSegmentMin 15 --chimMultimapNmax 20 --outSAMunmapped Within"
    }
    umi_tools {
        dedup_params = "--multimapping-detection NH"
    }
    shoji {
        gff3 = "/g/hentze/sequencing/gencode/V42/gencode.v42.annotation.plus.tRNAs.sorted.gff3"
        annotation_params = "--gene_id gene_id --gene_name gene_name --gene_type gene_type"
        tabix = true
        split_intron = true
        window = 100
        step = 20
        ignore_pcr_duplicates = false
        primary = true
        mate = 1
        site = "m"
        offset = 0
        extract_params = "-q 0 -f 0.9 -y 0.1"
        baseName = "test_out"
        suffix = ".parquet"
    }
    tracks{
        genome = "/g/hentze/sequencing/gencode/V42/GRCh38.primary_assembly.genome.fa.fai"
        params = "-bga"
    }
    singularity {
        qc = "/g/hentze/tools/Singularity_containers/quality-control_f42405cc.sif"
        trim = "/g/hentze/tools/Singularity_containers/trim_23eee457.sif"
        sourmash = "/g/hentze/tools/Singularity_containers/sourmash_ca5dd3ee.sif"
        bbmap = "/g/hentze/tools/Singularity_containers/bbmap_b1becb38.sif"
        star = "/g/hentze/tools/Singularity_containers/star_20207e54.sif"
        samtools = "/g/hentze/tools/Singularity_containers/samtools_2422331f.sif"
        umi_tools = "/g/hentze/tools/Singularity_containers/umi_tools_0ab95f04.sif"
        shoji = "/g/hentze/tools/Singularity_containers/shoji_1d16cf68.sif"
        genome_ops = "/g/hentze/tools/Singularity_containers/genome-ops_e5fb5eec.sif"
    }
}
